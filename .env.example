# Provectus Analytics — environment template
# Copy to `.env` for local development. Never commit `.env`.

# JWT signing key. Generate a fresh one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# REQUIRED when PROVECTUS_ENV=prod.
SECRET_KEY=

# 'dev' (default) allows a dev-only fallback secret. 'prod' fails fast if
# SECRET_KEY is missing.
PROVECTUS_ENV=dev

# Optional: seed an initial admin user on first startup. Only used when the
# users table is empty — never overwrites an existing user.
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# DB location. Defaults to <repo>/provectus.db locally. On Railway, mount a
# persistent volume at /data and set this to /data/provectus.db so the DB
# survives redeploys.
# DB_PATH=

# uvicorn port. Railway injects this automatically; local launcher defaults to 8050.
# PORT=8050
